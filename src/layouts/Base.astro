---
import '../styles/global.css';
const { title = 'Linggih Saputro — AI Engineer', description = 'Personal site and learning notes by Linggih Saputro, an AI engineer learning AI security and dependable AI engineering.' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  ['Writing', '/writing'], ['Learning', '/learning-path'], ['Projects', '/projects'],
  ['Lab Notes', '/labs'], ['About / CV', '/about']
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F2EFE7" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header shell">
      <a class="mark" href="/" aria-label="Home"><span>LS</span><small>AI ENGINEER / NOTES</small></a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-nav"><span>MENU</span><b aria-hidden="true">☰</b></button>
      <nav id="primary-nav" aria-label="Primary navigation">
        {nav.map(([label, href]) => <a href={href} class:list={{ active: path.startsWith(href) }}>{label}</a>)}
      </nav>
      <a class="github" href="https://github.com/nggih" target="_blank">GitHub ↗</a>
    </header>
    <main><slot /></main>
    <footer class="shell site-footer">
      <div><span class="pulse"></span> LEARNING IN PUBLIC</div>
      <p>Linggih Saputro · AI engineering, security, and dependable systems.</p>
      <p>© {new Date().getFullYear()} · <a href="https://github.com/nggih">GitHub</a></p>
    </footer>
    <script>
      const toggle = document.querySelector(".menu-toggle");
      const nav = document.querySelector("#primary-nav");
      toggle?.addEventListener("click", () => {
        const open = toggle.getAttribute("aria-expanded") === "true";
        toggle.setAttribute("aria-expanded", String(!open));
        nav?.classList.toggle("open", !open);
      });
      nav?.querySelectorAll("a").forEach(link => link.addEventListener("click", () => {
        toggle?.setAttribute("aria-expanded", "false");
        nav.classList.remove("open");
      }));
    </script>
  </body>
</html>
