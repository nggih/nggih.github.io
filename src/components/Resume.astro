---
const jobs = [
  { period:'Dec 2024 — Present', company:'Redpumpkin.AI', role:'Artificial Intelligence Engineer Manager', points:['Contributed to more than $500K in AWS GenAI and Agentic AI project delivery value.','Lead a 7-person cross-functional team; delivered more than 10 GenAI projects and PoCs.','Co-architected reusable agentic assistant foundations using Python, FastAPI, React/TypeScript, RAG, AWS, and MongoDB.'] },
  { period:'Dec 2023 — Dec 2024', company:'ICS Compute / Redpumpkin.AI', role:'Senior Artificial Intelligence Engineer', points:['Led a 5-person team delivering enterprise GenAI and Agentic AI solutions.','Designed and deployed virtual assistants, resume-screening, and legal GenAI applications from PoC to production.','Translated business needs into architectures using AWS, Python, FastAPI, LLMs, RAG, and vector databases.'] },
  { period:'Jun 2020 — Dec 2023', company:'SRW&Co.', role:'Senior Artificial Intelligence Engineer', points:['Designed and deployed production AI models with accuracy reaching 95% using Python and PyTorch.','Built NLP and automated-reporting solutions that reduced manual work.','Contributed to React and Next.js interfaces and cross-functional product delivery.'] },
  { period:'Aug 2021 — Dec 2022', company:'Johnson & Johnson via Turing', role:'Machine Learning Engineer — Contractor', points:['Prototyped image classification, object detection, voice-command, and information-retrieval solutions.','Built Python and PyTorch experiments achieving over 90% accuracy in selected projects.'] },
  { period:'Jul 2018 — May 2020', company:'Konvergen.AI', role:'Artificial Intelligence Engineer', points:['Led deep-learning implementation for a document retrieval system at Bank Central Asia.','Reduced annotation labor costs by 25% with AI-assisted text processing.','Improved model performance by 16% through feature engineering and ensembles.'] }
];
const certs = [['AWS Certified AI Practitioner','Sep 2024 — Mar 2028'],['AWS Certified Machine Learning Engineer — Associate','Mar 2025 — Mar 2028'],['Databricks Certified Generative AI Engineer Associate','May 2025 — May 2027'],['Databricks Certified Data Engineer Professional','Jun 2025 — Jun 2027'],['Databricks Certified Machine Learning Professional','Sep 2025 — Sep 2027']];
---
<section class="cv-band"><div class="shell cv-grid"><div><span>01 /</span><h2>Location</h2><p>Jakarta, Indonesia</p></div><div><span>02 /</span><h2>Current role</h2><p>AI Engineer Manager<br/>Redpumpkin.AI</p></div><div><span>03 /</span><h2>Current direction</h2><p>AI security<br/>Agent security<br/>Dependable AI</p></div></div></section>
<section class="shell resume-section"><div class="section-head"><h2><span>01 /</span>Professional experience</h2></div><div class="experience-list">{jobs.map(job => <article><aside><strong>{job.period}</strong><span>{job.company}</span></aside><div><h3>{job.role}</h3><ul>{job.points.map(point => <li>{point}</li>)}</ul></div></article>)}</div></section>
<section class="resume-paper"><div class="shell resume-columns"><div><div class="section-head"><h2><span>02 /</span>Education</h2></div><article class="credential"><span>2016 — 2018</span><h3>Master of Science</h3><p>Bioinformatics and Computational Biology<br/>University of South Florida</p><small>CGPA 3.49 / 4.00</small></article></div><div><div class="section-head"><h2><span>03 /</span>Skills</h2></div><div class="skill-groups"><p><strong>Languages</strong>Python, JavaScript, TypeScript, Golang, Rust</p><p><strong>AI / ML</strong>PyTorch, TensorFlow, LLMs, RAG, agentic orchestration</p><p><strong>Engineering</strong>FastAPI, React, Next.js, Vue, PostgreSQL, MongoDB</p><p><strong>Cloud / Platform</strong>AWS, Kubernetes, EKS, Docker, Databricks</p></div></div></div></section>
<section class="shell resume-section"><div class="section-head"><h2><span>04 /</span>Certifications</h2></div><div class="cert-grid">{certs.map(([name,date]) => <article><span>{date}</span><h3>{name}</h3></article>)}</div></section>
