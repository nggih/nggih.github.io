---
import Base from '../../layouts/Base.astro'; import {getCollection} from 'astro:content'; const labs=await getCollection('labs');
---
<Base title="Lab Notes — Linggih Saputro"><section class="shell page-head"><div class="eyebrow">EXPERIMENT LOG / LIVE</div><h1>Red Team Lab Notes</h1><p>Reproducible experiments, observations, mitigations, and remaining weaknesses.</p></section><section class="shell block"><div class="lab-grid">{labs.map((lab,i)=><article><div><span>LAB—{String(i+1).padStart(3,'0')}</span><span class={`severity ${lab.data.severity}`}>{lab.data.severity}</span></div><h2>{lab.data.title}</h2><p>{lab.data.description}</p><footer><span>TARGET: {lab.data.target}</span><span>{lab.data.status}</span></footer></article>)}</div></section></Base>
